<h1>Painel Admin</h1>

<%= button_to "Logout", "/logout", method: :delete %>

<%= link_to "Criar usuário", new_user_path %>

<ul>
  <% @users.each do |user| %>
    <li>
      <%= user.name %> - <%= user.email %>

      <%= link_to "Editar", edit_user_path(user) %>

      <%= button_to "Excluir", user_path(user), method: :delete %>
    </li>
  <% end %>
</ul>