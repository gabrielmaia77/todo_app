<h1 class="titulo">Painel Admin</h1>

<div class="top-bar">
  <%= link_to "Criar usuário", new_user_path, class: "btn btn-primary" %>
  <%= button_to "Logout", "/logout", method: :delete, class: "btn btn-logout" %>
</div>

<ul class="lista-usuarios">
  <% @users.each do |user| %>
    <li class="usuario-item">
      <span class="usuario-info">
        <strong><%= user.name %></strong> - <%= user.email %>
      </span>

      <div class="acoes">
        <%= link_to "Editar", edit_user_path(user), class: "btn btn-edit" %>

        <%= button_to "Excluir", user_path(user),
          method: :delete,
          class: "btn btn-delete",
          form: { style: "display:inline;" } %>
      </div>
    </li>
  <% end %>
</ul>