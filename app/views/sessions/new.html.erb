<div class="container">
  <h1>blue_task</h1>

  <% if flash[:alert] %>
    <p class="error"><%= flash[:alert] %></p>
  <% end %>

  <h2>Login</h2>

  <%= form_with url: "/login", method: :post do %>
    <%= email_field_tag :email, nil, placeholder: "Email" %>
    <%= password_field_tag :password, nil, placeholder: "Senha" %>
    <%= submit_tag "Entrar" %>
  <% end %>
</div>